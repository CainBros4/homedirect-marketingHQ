# HomeDirectAI Marketing Hub — Environment Variables
# Copy this file to .env and fill in your keys.
# .env is gitignored and should NEVER be committed.
#
# For production (Railway): add these in the Railway dashboard
# under your service → Variables tab.

# ── AI Provider Keys ─────────────────────────────────────────────────────────
# Only the key for your active provider is required.
# Get Together AI key: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# Get OpenAI key: https://platform.openai.com/api-keys
# Use a restricted key with only the permissions needed (chat completions).
OPENAI_API_KEY=

# Get DeepSeek key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Get Fireworks key: https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=

# ── Video Generator ─────────────────────────────────────────────────────────
# ElevenLabs TTS (voiceover): https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Pexels (b-roll footage): https://www.pexels.com/api/
PEXELS_API_KEY=

# ── Publishing & Scheduling ──────────────────────────────────────────────────
# Buffer API token — enables auto-publishing to social media from the Publish Queue.
# Get from: https://buffer.com/developers/api
BUFFER_ACCESS_TOKEN=

# ── App Config ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Shared Database (Postgres) ───────────────────────────────────────────────
# Set this to share tables with homedirect (users, listings, etc.).
# When unset, marketing tables go into local marketing-hub.db (SQLite) and
# admin auth falls back to MARKETING_ADMIN_PASSWORD.
# Railway: copy the DATABASE_URL from the homedirect service's Variables tab.
DATABASE_URL=

# ── Session / Auth ───────────────────────────────────────────────────────────
# Secret for session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# Admin password for the /marketing UI when DATABASE_URL is not set.
# Ignored when DATABASE_URL is set (users table is used instead).
MARKETING_ADMIN_PASSWORD=

# ── Email Marketing (Resend) ─────────────────────────────────────────────────
# Resend API key: https://resend.com/api-keys
RESEND_API_KEY=
# Sending identity. Use onboarding@resend.dev for a sandbox test without DNS,
# or a verified domain like marketing@trykeylime.ai.
RESEND_FROM_EMAIL=marketing@trykeylime.ai
RESEND_FROM_NAME=Key Lime
# Optional webhook signing secret (Resend dashboard → Webhooks).
RESEND_WEBHOOK_SECRET=

# ── Anthropic (Claude API for AI template + drip generation) ─────────────────
# Key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-sonnet-4-6)
ANTHROPIC_MODEL=

# ── Public App URL (for unsubscribe links) ───────────────────────────────────
# Dev: http://localhost:5000
# Prod: https://marketinghq-production.up.railway.app (or your custom domain)
APP_BASE_URL=http://localhost:5000

# ── MLS Data Providers (swappable) ───────────────────────────────────────────
# bridge (today, free FSBO tier) or stellar (once brokerage license lands)
MLS_PROVIDER=bridge
BRIDGE_API_TOKEN=
BRIDGE_DATASET=zillow-fsbo
STELLAR_API_TOKEN=
STELLAR_API_BASE=

# ── Skip Tracing ─────────────────────────────────────────────────────────────
# BatchData / BatchSkipTracing: https://batchskiptracing.com
BATCH_SKIP_TRACING_API_KEY=
